rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can only access their own audio files
    match /voices/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /generations/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
